df_cal = pd.read_excel(input_file, sheet_name='CAL')

# 2. Check if the mapping file already exists (the "Rerun" logic)
if os.path.exists(mapping_file):
    print(f"Found existing {mapping_file}. Applying manual mappings...")
    mapping_df = pd.read_excel(mapping_file)
    
    # Create a dictionary for renaming: {Old_Name: New_Name}
    # We drop empty 'New_Logical_Name' rows so we only rename what you've filled in
    name_map = mapping_df.dropna(subset=['New_Logical_Name']).set_index('Source_Logical_Name')['New_Logical_Name'].to_dict()
    
    # Apply the mapping to both sheets BEFORE the join
    df_cat['Logical_Name'] = df_cat['Logical_Name'].replace(name_map)
    df_cal['Logical_Name'] = df_cal['Logical_Name'].replace(name_map)
else:
    print(f"No mapping file found. Generating {mapping_file} for your review...")

# 3. Create a unique list of all Logical Names from both sides for the template
all_names = pd.concat([
    df_cat[['Logical_Name', 'CDM_Path']].assign(Source='CAT'),
    df_cal[['Logical_Name', 'CDM_Path']].assign(Source='CAL')
])

